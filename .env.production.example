# Production Environment Variables Template
# Copy this file to .env.production and fill in actual values

# Database Configuration
DB_SA_PASSWORD=YourStrongPassword123!
DB_NAME=PatientManagementDb

# JWT Authentication
JWT_SECRET=YourJwtSecretKeyAtLeast32CharactersLong!
JWT_ISSUER=PatientManagementAPI
JWT_AUDIENCE=PatientManagementApp
JWT_EXPIRY_HOURS=8

# API Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:443;http://+:80

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Serilog Configuration
SERILOG_MINIMUM_LEVEL=Information
SERILOG_FILE_PATH=/app/logs/patient-management-.log
SERILOG_RETENTION_DAYS=30

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups

# Email Configuration (for alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=YourSmtpPassword
ALERT_EMAIL=admin@yourdomain.com

# Application Settings
CLINIC_NAME=Your Clinic Name
CLINIC_ADDRESS=Your Clinic Address
CLINIC_PHONE=+1234567890
